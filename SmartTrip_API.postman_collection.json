{
  "info": {
    "name": "SmartTrip API - Week 4",
    "description": "REST API endpoints for SmartTrip Planner with JWT Auth and Validation fixes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json();",
                  "if (data.access_token) {",
                  "    pm.environment.set('token', data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "srishti@example.com",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "password123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:8000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Trips",
      "item": [
        {
          "name": "List All Trips",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/trips",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "trips"]
            }
          }
        },
        {
          "name": "Create a Trip",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"Monteverde Cloud Forest, Costa Rica\",\n  \"date\": \"Nov 2026\",\n  \"duration\": \"7 days\",\n  \"budget\": \"$1,500\",\n  \"eco_score\": 96,\n  \"status\": \"planning\",\n  \"tags\": [\"Eco-Tourism\", \"Nature\"],\n  \"activities\": [\"Canopy Tour\", \"Hiking\"],\n  \"image\": \"🌿\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/trips",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "trips"]
            }
          }
        },
        {
          "name": "Search Trips",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/trips/search?q=Costa",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "trips", "search"],
              "query": [{"key": "q", "value": "Costa"}]
            }
          }
        },
        {
          "name": "Get Single Trip",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/trips/trip-001",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "trips", "trip-001"]
            }
          }
        },
        {
          "name": "Update Trip",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"budget\": \"$1,800\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/trips/trip-001",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "trips", "trip-001"]
            }
          }
        },
        {
          "name": "Delete Trip",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/trips/trip-001",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "trips", "trip-001"]
            }
          }
        }
      ]
    }
  ]
}
